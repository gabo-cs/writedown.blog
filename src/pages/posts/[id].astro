---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description} image={post.data.image}>
  <article>
    <h1 class="text-3xl font-bold tracking-tight mb-2">{post.data.title}</h1>
    <div class="text-sm text-neutral-400 mb-10">
      <time datetime={post.data.date.toISOString().slice(0, 10)}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <span class="mx-2">&middot;</span>
      <span>{post.data.author}</span>
    </div>
    {post.data.image && (
      <div class="aspect-video w-full overflow-hidden rounded-md mb-10">
        <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
      </div>
    )}
    <div class="prose prose-neutral prose-lg">
      <Content />
    </div>
  </article>
</Base>
