---
import Base from '../layouts/Base.astro';
---

<Base title="About - WriteDown.Blog">
  <h1 class="text-3xl font-bold tracking-tight mb-8">About</h1>
  <div class="text-lg text-neutral-700 leading-relaxed space-y-4">
    <p>WriteDown.Blog is a free, open blogging platform where anyone can publish.</p>
    <p>
      There are no accounts, no ads, no algorithms. Just Markdown files in a Git repo.
      You publish by opening a pull request.
    </p>
    <p>Write about whatever you care about. If it's thoughtful, it belongs here.</p>
    <p class="text-neutral-400 text-base pt-4">
      Want to publish a post? Check out <a href="/publish" class="underline hover:text-neutral-600">How to Publish</a> — no dev experience needed.
    </p>
  </div>
</Base>
