---
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const {
    title,
    description = "An open blogging platform. Publish by submitting a pull request.",
    image,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="canonical" href={canonicalURL} />
        <title>{title}</title>

        <!-- Open Graph -->
        <meta property="og:type" content="article" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        {ogImage && <meta property="og:image" content={ogImage} />}

        <!-- Twitter -->
        <meta
            name="twitter:card"
            content={ogImage ? "summary_large_image" : "summary"}
        />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        {ogImage && <meta name="twitter:image" content={ogImage} />}
    </head>
    <body class="bg-white text-neutral-900 antialiased">
        <div class="max-w-2xl mx-auto px-6">
            <header
                class="flex justify-between items-center py-6 border-b border-neutral-200"
            >
                <a
                    href="/"
                    class="text-lg font-semibold tracking-tight hover:text-neutral-600"
                    >WriteDown.Blog</a
                >
                <nav class="flex gap-4">
                    <a
                        href="/publish"
                        class="text-sm text-neutral-500 hover:text-neutral-900"
                        >Publish</a
                    >
                    <a
                        href="/about"
                        class="text-sm text-neutral-500 hover:text-neutral-900"
                        >About</a
                    >
                </nav>
            </header>

            <main class="py-16">
                <slot />
            </main>

            <footer
                class="border-t border-neutral-200 py-10 text-sm text-neutral-400 leading-relaxed"
            >
                <p>
                    Got something to say? <a
                        href="/publish"
                        class="underline hover:text-neutral-600"
                        >Learn how to publish</a
                    > — all you need is a GitHub account.
                </p>
            </footer>
        </div>
    </body>
</html>
